# 基础
PORT=3000
JWT_SECRET=replace-with-a-long-random-string
LOCAL_AUTH_BYPASS=false

# 数据库：MySQL/TiDB，月报导入缓存和登录用户会写入这里
DATABASE_URL=mysql://user:password@host:3306/category_weekly_report

# 飞书登录
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx
FEISHU_REDIRECT_BASE_URL=http://localhost:3000

# Manus OAuth 兼容项：当前页面主要用飞书登录，迁出 Manus 后通常可留空
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=

# AI 分析：推荐迁移到 OpenAI-compatible Chat Completions 接口
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=

# Dify AI 分析：如果设置了这两项，AI 模块会优先调用公司 Dify 工作流
# DIFY_API_URL 可填 https://your-dify-domain/v1 或 https://your-dify-domain/v1/workflows/run
DIFY_API_URL=https://dify.kapeixi.cn/v1
DIFY_API_KEY=
DIFY_USER=category-weekly-report

# Hengshi SKC basic tags: used by bestseller-element AI analysis
HENGSHI_SKC_BASE_URL=https://hengshi-eu.kapeixi.cn/api/open/get/skc/data/base
HENGSHI_CLIENT_ID=
HENGSHI_CLIENT_SECRET=

# 旧 Manus Forge 兼容项：如果继续使用旧接口，可以填这里
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_MODEL=gemini-2.5-flash
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# Google Sheets：当前代码直接读取固定 Sheet 的 CSV 导出链接；如果表格不是公开可访问，需要后续改成凭证读取
GOOGLE_SHEETS_SERVICE_ACCOUNT=
GOOGLE_SHEETS_API_KEY=

# 前端展示
VITE_APP_TITLE=品类运营周报系统
VITE_APP_LOGO=
